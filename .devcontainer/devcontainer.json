{
  "name": "GNX Dev Environment",
  "image": "ghcr.io/arminms/gnx:latest",
  "forwardPorts": [8888],
  "postStartCommand": "jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --ServerApp.token='' --ServerApp.password='' --ServerApp.default_url='/lab/tree/doc/notebooks/sandbox.md'",
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers",
        "ms-vscode.hexeditor",
        "executablebookproject.myst-highlight",
        "ms-python.python",
        "congyiwu.vscode-jupytext",
        "ms-toolsai.jupyter-keymap",
        "vscode-icons-team.vscode-icons",
        "github.vscode-pull-request-github",
        "eamodio.gitlens",
        "mutantdino.resourcemonitor"
      ]
    }
  }
}
